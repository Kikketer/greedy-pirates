     break;" line12="        case States.AllDead:" line13="            AllDead.init()" line14="        break;" line15="        case States.GameOver:" line16="            GameOver.init()" line17="        break;" line18="        case States.Win:" line19="            Win.init()" line20="        break;" line21="        case States.Travel:" line22="            Travel.init({ targetIsland: currentIsland })" line23="        break;" line24="        case States.TreasureIsland:" line25="            TreasureIsland.init()" line26="        break;" line27="        case States.Menu:" line28="        default:" line29="            Menu.init()" line30="    }" line31="}" numlines="32"></mutation><next><block type="typescript_statement" id="/gN]c[Ee:!bE+uwj%eQ-"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="function startGame(initialState?: States) {" line1="    Map.onSelectIsland((island: Map.Island) =&gt; {" line2="        if (currentIsland &amp;&amp; island.id !== currentIsland.id) {" line3="            currentIsland = island" line4="            switchState(States.Travel)" line5="        } else if (island.id === 0) {" line6="            currentIsland = island" line7="            switchState(States.TreasureIsland)" line8="        } else {" line9="            currentIsland = island" line10="            // If you re-select the same island you don't floatyboaty" line11="            switchState(States.Island)" line12="        }" line13="    })" line14="    Map.onWin(() =&gt; {" line15="        switchState(States.Win)" line16="    })" line17="" line18="    Island.onLeaveIsland(() =&gt; {" line19="        switchState(States.Overview)" line20="    })" line21="    Island.onAllDead(() =&gt; {" line22="        if (PirateLives.currentPirateCount &lt;= 0) {" line23="            switchState(States.GameOver)" line24="        } else {" line25="            switchState(States.AllDead)" line26="        }" line27="    })" line28="" line29="    BoatBattle.onWin(() =&gt; {" line30="        if (currentIsland.id === 0) {" line31="            switchState(States.TreasureIsland)" line32="        } else {" line33="            switchState(States.Island)" line34="        }" line35="    })" line36="    BoatBattle.onLoose(() =&gt; {" line37="        if (PirateLives.currentPirateCount &lt;= 0) {" line38="            switchState(States.GameOver)" line39="        } else if (currentIsland.id === 0) {" line40="            switchState(States.TreasureIsland)" line41="        } else {" line42="            switchState(States.Overview)" line43="        }" line44="    })" line45="" line46="    Travel.onBoatBattle(() =&gt; {" line47="        switchState(States.BoatBattle)" line48="    })" line49="    Travel.onLandOnIsland(() =&gt; {" line50="        currentIsland = currentIsland ? currentIsland : Map.islands[0]" line51="        if (currentIsland.id === 0) {" line52="            // Our own Island" line53="            switchState(States.TreasureIsland)" line54="        } else {" line55="            switchState(States.Island)" line56="        }" line57="    })" line58="" line59="    TreasureIsland.onComplete(() =&gt; {" line60="        switchState(States.Overview)" line61="    })" line62="" line63="    Menu.onStartGame(() =&gt; {" line64="        switchState(States.Overview)" line65="    })" line66="" line67="    AllDead.onRevive(() =&gt; {" line68="        switchState(States.Overview)" line69="    })" line70="" line71="    switchState(initialState ? initialState : States.Menu)" line72="}" numlines="73"></mutation><next><block type="typescript_statement" id="T.Pf;3z,WS.+]v0Bl[=k"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="startGame()" numlines="1"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="gameupdate" id="%iW7CYN~/ZH$KY9Yq4Pq" x="765" y="0"><statement name="HANDLER"><block type="typescript_statement" id="eX98,GGvNBMCU12(_)Zy"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="switch(currentState) {" line1="        case States.Overview:" line2="            Map.render()" line3="            break;" line4="        case States.Island:" line5="            Island.render();" line6="            break;" line7="        case States.BoatBattle:" line8="            BoatBattle.render()" line9="            break;" line10="        case States.TreasureIsland:" line11="            TreasureIsland.render()" line12="            break;" line13="        default:" line14="        break;" line15="    }" numlines="16"></mutation></block></statement></block></xml>